###soft delete post
DELETE http://localhost:5000/api/posts/REPLACE_WITH_POST_ID
Content-Type: application/json
Authorization: Bearer <token>

# ── COMMENTS ─────────────────────────────────────────────────────────────────

###get comments for a post
GET http://localhost:5000/api/comments/REPLACE_WITH_POST_ID
Content-Type: application/json
Authorization: Bearer <token>

###add comment to a post
POST http://localhost:5000/api/comments/REPLACE_WITH_POST_ID
Content-Type: application/json
Authorization: Bearer <token>

{
    "text": "Great post!"
}

###delete comment
DELETE http://localhost:5000/api/comments/REPLACE_WITH_COMMENT_ID
Content-Type: application/json
Authorization: Bearer <token>

# ── USERS ─────────────────────────────────────────────────────────────────────

###get user by id
GET http://localhost:5000/api/users/69b8e651f664aae730a862dc
Content-Type: application/json
Authorization: Bearer <token>

###search user
GET http://localhost:5000/api/users/search?q=subhash
Content-Type: application/json
Authorization: Bearer <token>

###update user
PUT http://localhost:5000/api/users/69b8e651f664aae730a862dc
Content-Type: application/json
Authorization: Bearer <token>

{
    "username": "Subhash",
    "bio": "Hello, I am Subhash!"
}

###follow or unfollow user (toggle)
POST http://localhost:5000/api/users/REPLACE_WITH_USER_ID/follow
Content-Type: application/json
Authorization: Bearer <token>

###get following list
GET http://localhost:5000/api/users/69b8e651f664aae730a862dc/following
Content-Type: application/json
Authorization: Bearer <token>

###get followers list
GET http://localhost:5000/api/users/69b8e651f664aae730a862dc/followers
Content-Type: application/json
Authorization: Bearer <token>
